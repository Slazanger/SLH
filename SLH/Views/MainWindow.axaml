<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SLH.ViewModels"
        xmlns:v="using:SLH.Views"
        xmlns:c="using:SLH.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="SLH.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SLH — More Medium than Small"
        Width="1100" Height="720"
        MinWidth="880" MinHeight="560">

    <Window.Resources>
        <c:BoolBrushConverter x:Key="EsiDotBrush">
            <c:BoolBrushConverter.WhenTrue>
                <SolidColorBrush Color="#22c55e"/>
            </c:BoolBrushConverter.WhenTrue>
            <c:BoolBrushConverter.WhenFalse>
                <SolidColorBrush Color="#52525b"/>
            </c:BoolBrushConverter.WhenFalse>
        </c:BoolBrushConverter>
        <c:BoolBrushConverter x:Key="OnlineDotBrush">
            <c:BoolBrushConverter.WhenTrue>
                <SolidColorBrush Color="#38bdf8"/>
            </c:BoolBrushConverter.WhenTrue>
            <c:BoolBrushConverter.WhenFalse>
                <SolidColorBrush Color="#52525b"/>
            </c:BoolBrushConverter.WhenFalse>
        </c:BoolBrushConverter>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*" Margin="12">
        <Border Grid.Row="0" Classes="glass" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="6" Background="#111827" BorderBrush="#334155" BorderThickness="1">
                        <TextBlock Text="♦" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Header.CharacterDisplayName}" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="{Binding Header.SystemLine}" Opacity="0.85" FontSize="13"/>
                        <TextBlock Text="{Binding Header.LocalLine}" Opacity="0.85" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="ESI" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="●" FontSize="14" HorizontalAlignment="Center"
                                   Foreground="{Binding Header.EsiConnected, Converter={StaticResource EsiDotBrush}}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Online" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="●" FontSize="14" HorizontalAlignment="Center"
                                   Foreground="{Binding Header.IntelConnected, Converter={StaticResource OnlineDotBrush}}"/>
                    </StackPanel>
                    <Button Content="Log in (EVE)" Command="{Binding LoginCommand}" Padding="12,6" Margin="8,0,0,0"/>
                    <Button Content="⟳" Command="{Binding RefreshNowCommand}" Padding="10,6" ToolTip.Tip="Refresh location"/>
                    <Button Content="☰" Command="{Binding OpenSettingsTabCommand}" Padding="10,6" ToolTip.Tip="Settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Local Analyser">
                <v:LocalAnalyserView DataContext="{Binding Local}"/>
            </TabItem>
            <TabItem Header="Dscan Analyser">
                <v:DscanView DataContext="{Binding Dscan}"/>
            </TabItem>
            <TabItem Header="Character Look up">
                <v:CharacterLookupView DataContext="{Binding Lookup}"/>
            </TabItem>
            <TabItem Header="Settings">
                <v:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
