<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SLH.ViewModels"
        xmlns:v="using:SLH.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="680" d:DesignHeight="480"
        x:Class="SLH.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app.ico"
        Title="SLH - Not really little, more medium [v0.1 2026-04-06]"
        Width="680" Height="480"
        MinWidth="680" MinHeight="380">

    <Grid Margin="4">
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" Padding="0">
            <TabItem Header="Local">
                <v:LocalAnalyserView DataContext="{Binding Local}"/>
            </TabItem>
            <TabItem Header="D-Scan" IsVisible="false">
                <v:DscanView DataContext="{Binding Dscan}"/>
            </TabItem>
            <TabItem Header="Character">
                <v:CharacterLookupView DataContext="{Binding Lookup}"/>
            </TabItem>
            <TabItem Header="Settings">
                <v:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
