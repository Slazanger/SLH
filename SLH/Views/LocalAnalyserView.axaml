<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:hexconv="using:SLH.Converters"
             xmlns:vm="using:SLH.ViewModels"
             x:Class="SLH.Views.LocalAnalyserView"
             x:DataType="vm:LocalAnalyserViewModel">

    <UserControl.Resources>
        <ContextMenu x:Key="LocalPilotsContextMenu">
            <MenuItem Header="Paste" Click="OnPasteLocalClick"/>
            <MenuItem Header="Clear" Click="OnClearLocalClick"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid ColumnDefinitions="*,248" Margin="0,2,0,0">
        <Grid Grid.Column="0" RowDefinitions="*" Margin="0,0,6,0">
            <Border x:Name="LocalPilotsHost" Classes="glass" Padding="4" ToolTip.Tip="Right-click for Paste or Clear">
                <ListBox ItemsSource="{Binding Pilots}" SelectedItem="{Binding SelectedPilot}"
                         Background="#0d1118" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PilotRowViewModel">
                            <Border BorderThickness="3,0,0,0"
                                    BorderBrush="{Binding StandingForeground, Converter={x:Static hexconv:HexColorToBrushConverter.Instance}}"
                                    Padding="2,0,0,0">
                            <Grid ColumnDefinitions="28,*,Auto,Auto" Margin="1,0">
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="0" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" VerticalAlignment="Center">
                                    <TextBlock Text="♦" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5a7090"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Subtitle}" FontWeight="SemiBold" FontSize="11"
                                               Foreground="{Binding StandingForeground, Converter={x:Static hexconv:HexColorToBrushConverter.Instance}}"/>
                                    <TextBlock Text="{Binding Name}" Opacity="0.55" FontSize="9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="☠" Opacity="0.65" FontSize="10"/>
                                    <TextBlock Text="{Binding ThreatScore}" Foreground="#F57C00" FontWeight="SemiBold" FontSize="11" MinWidth="18"/>
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="✓" Foreground="#388E3C" FontSize="10" VerticalAlignment="Center"
                                           IsVisible="{Binding IsFriendly}"/>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Column="1" Classes="glass" Padding="6">
            <ScrollViewer>
                <StackPanel Spacing="4">
                    <TextBlock Text="Pilot" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8"/>

                    <StackPanel IsVisible="{Binding SelectedPilot, Converter={x:Static conv:ObjectConverters.IsNotNull}}" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="44" Height="44" CornerRadius="0" Background="#0a0e14" BorderBrush="#2A4B7C" BorderThickness="1">
                                <TextBlock Text="♦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#5a7090"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedPilot.Subtitle}" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{Binding SelectedPilot.StandingForeground, Converter={x:Static hexconv:HexColorToBrushConverter.Instance}}"/>
                                <Border Padding="4,2" Margin="0,3,0,0" HorizontalAlignment="Left" Background="#8B1538" BorderBrush="#D32F2F" BorderThickness="1">
                                    <TextBlock Foreground="#f0f4f8" FontWeight="SemiBold" FontSize="10">
                                        <Run Text="{Binding SelectedPilot.ThreatLabel}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding SelectedPilot.ThreatScore}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="10">
                            <Run Text="Kills " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsDestroyed}"/>
                            <Run Text="  Losses " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsLost}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedPilot.ShipsHint}" TextWrapping="Wrap" Opacity="0.8" FontSize="10"/>
                        <TextBlock Text="{Binding SelectedPilot.ActivityRegion}" FontWeight="SemiBold" FontSize="10" Foreground="#00a8b8"/>
                        <TextBlock Text="Activity (UTC, zKill)" Opacity="0.5" FontSize="9"/>
                        <ItemsControl ItemsSource="{Binding SelectedPilot.ActivityBuckets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="sys:Int32">
                                    <Border Width="6" MaxHeight="40" MinHeight="2" VerticalAlignment="Bottom"
                                            Height="{Binding}" Background="#F57C00" CornerRadius="0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="10" Foreground="#00b8c8"/>
                        <TextBlock Text="{Binding DetailNotes}" TextWrapping="Wrap" Opacity="0.9" FontSize="10"/>
                        <TextBlock Text="{Binding SelectedPilot.IntelTip}" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.75" FontSize="10"/>
                    </StackPanel>

                    <TextBlock Text="Select a pilot."
                               IsVisible="{Binding SelectedPilot, Converter={x:Static conv:ObjectConverters.IsNull}}"
                               Opacity="0.5" FontSize="10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
