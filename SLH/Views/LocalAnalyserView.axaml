<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalconv="using:Avalonia.Data.Converters"
             xmlns:slh="using:SLH.Converters"
             xmlns:vm="using:SLH.ViewModels"
             xmlns:services="using:SLH.Services"
             xmlns:views="using:SLH.Views"
             x:Class="SLH.Views.LocalAnalyserView"
             x:DataType="vm:LocalAnalyserViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <ContextMenu x:Key="LocalPilotsContextMenu">
            <MenuItem Header="Paste" Click="OnPasteLocalClick"/>
            <MenuItem Header="Clear" Click="OnClearLocalClick"/>
            <Separator/>
            <MenuItem Header="Custom tag">
                <MenuItem Header="FC" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="Cloaky Camper" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="JF Hunter" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="Ganker" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="0,2,0,0" MinHeight="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
          RowDefinitions="*,Auto">
        <Grid Grid.Row="0" MinHeight="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="300" MinWidth="280"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" RowDefinitions="*" Margin="0,0,6,0" MinHeight="0" VerticalAlignment="Stretch">
            <Border x:Name="LocalPilotsHost" Classes="glass" Padding="2" MinHeight="0" VerticalAlignment="Stretch"
                    ToolTip.Tip="Ctrl+V or right-click Paste: replace local from clipboard. Ctrl+P: merge paste. Right-click: Clear.">
                <Grid MinHeight="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Image Source="avares://SLH/Assets/local-empty-duck.png"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="16"
                           Opacity="0.01"
                           IsVisible="{Binding ShowLocalEmptyPlaceholder}"/>
                    <ListBox x:Name="LocalPilotsList" ItemsSource="{Binding Pilots}" SelectedItem="{Binding SelectedPilot}"
                         Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                         DoubleTapped="OnLocalPilotsDoubleTapped"
                         ToolTip.Tip="Double-click: open zKill (when character ID is resolved). Ctrl+V: replace paste. Ctrl+P: merge paste. Right-click: menu.">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="2,2"/>
                            <Setter Property="MinHeight" Value="28"/>
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(odd) /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0a1016"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PilotRowViewModel">
                            <Grid ColumnDefinitions="3,*" Margin="0,0,15,0">
                            <Border Grid.Column="0" Width="3" VerticalAlignment="Stretch"
                                    Background="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}">
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                </ToolTip.Tip>
                            </Border>
                            <DockPanel Grid.Column="1" LastChildFill="True" Margin="2,0,0,0">
                                <!-- Dock Right: first = outermost right — tags + threat grouped on the right -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <Border Padding="4,1" CornerRadius="2" Background="#1a3a4a" BorderBrush="#2a5a6a"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding ShowFcBadge}">
                                        <TextBlock Text="FC" FontSize="8" FontWeight="SemiBold" Foreground="#7ec8e8" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#2a1f32" BorderBrush="#5a3a6a"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagCloakyCamper}">
                                        <TextBlock Text="Cloaky" FontSize="8" FontWeight="SemiBold" Foreground="#CE93D8" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#2a2618" BorderBrush="#8D6E63"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagJfHunter}">
                                        <TextBlock Text="JF" FontSize="8" FontWeight="SemiBold" Foreground="#FFCC80" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#3a1a1a" BorderBrush="#c62828"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagGanker}">
                                        <TextBlock Text="Gank" FontSize="8" FontWeight="SemiBold" Foreground="#ef9a9a" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="2,0,4,0">
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap1, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip1}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap1}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap2, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip2}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap2}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap3, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip3}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap3}" Stretch="UniformToFill"/>
                                        </Border>
                                    </StackPanel>
                                    <Panel VerticalAlignment="Center">
                                        <Border Padding="5,3" BorderThickness="1" Background="#2a1f32" BorderBrush="#7B1FA2"
                                                IsVisible="{Binding ShowThreatPendingPlaceholder}">
                                            <TextBlock Text="????" FontWeight="SemiBold" FontSize="9" Foreground="#CE93D8"
                                                       ToolTip.Tip="zKill threat not loaded yet"/>
                                        </Border>
                                        <Border Padding="4,2" BorderThickness="1"
                                                Background="{Binding ThreatBadgeBackground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                                BorderBrush="{Binding ThreatBadgeBorderBrush, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                                IsVisible="{Binding ShowThreatBadgeValues}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding ThreatLabel}" FontWeight="SemiBold" FontSize="9"
                                                           Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                                <TextBlock Text="{Binding ThreatScore}" FontWeight="SemiBold" FontSize="9" MinWidth="14"
                                                           Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center" Margin="8,0,0,0"
                                        IsVisible="{Binding HasZkillCynoHint}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <TextBlock Text="cyno" FontSize="8" Foreground="#CE93D8" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock DockPanel.Dock="Right" Text="?" FontSize="10" Foreground="#9a8a70" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Margin="8,0,0,0" ToolTip.Tip="Resolving character…"
                                           IsVisible="{Binding IsCharacterUnresolved}"/>

                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Panel Width="20" Height="20" VerticalAlignment="Center">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <Border Width="20" Height="20" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True">
                                            <Image Width="20" Height="20" Source="{Binding PortraitBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}"/>
                                        </Border>
                                        <TextBlock Text="♦" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5a7090"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNull}}"/>
                                    </Panel>
                                    <Border Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontSize="12" LineHeight="15" TextTrimming="CharacterEllipsis"
                                                       Opacity="{Binding ListNameOpacity}"
                                                       Foreground="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            <TextBlock Text="{Binding CorpTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="#8a9aaa" IsVisible="{Binding HasCorpTicker}"/>
                                            <TextBlock Text="{Binding AllianceTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="#9aaa8a" IsVisible="{Binding HasAllianceTicker}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" Background="#2d3d50" ResizeDirection="Columns"/>

        <Border Grid.Column="2" Classes="glass" Padding="8" VerticalAlignment="Stretch" MinHeight="0">
            <ScrollViewer Padding="0,0,0,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <views:PilotDetailPanelView HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </ScrollViewer>
        </Border>
        </Grid>

        <Border Grid.Row="1" Classes="glass" Padding="8,5" Margin="0,4,0,0"
                BorderBrush="#2d3d50" BorderThickness="0,1,0,0" Background="#0a1016">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Pilots:" FontSize="11" Foreground="#8a9aaa" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusPilotCount}" FontSize="11" Foreground="#d0dae8" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="|" FontSize="11" Foreground="#3d4d60" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Remaining:" FontSize="11" Foreground="#8a9aaa" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusRemainingCount}" FontSize="11" Foreground="#d0dae8" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="|" FontSize="11" Foreground="#3d4d60" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Errors:" FontSize="11" Foreground="#8a9aaa" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusErrorCount}" FontSize="11" Foreground="#d0dae8" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
