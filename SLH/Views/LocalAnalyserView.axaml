<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalconv="using:Avalonia.Data.Converters"
             xmlns:slh="using:SLH.Converters"
             xmlns:vm="using:SLH.ViewModels"
             xmlns:services="using:SLH.Services"
             x:Class="SLH.Views.LocalAnalyserView"
             x:DataType="vm:LocalAnalyserViewModel">

    <UserControl.Resources>
        <ContextMenu x:Key="LocalPilotsContextMenu">
            <MenuItem Header="Paste" Click="OnPasteLocalClick"/>
            <MenuItem Header="Clear" Click="OnClearLocalClick"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid ColumnDefinitions="*,248" Margin="0,2,0,0">
        <Grid Grid.Column="0" RowDefinitions="*" Margin="0,0,6,0">
            <Border x:Name="LocalPilotsHost" Classes="glass" Padding="2" ToolTip.Tip="Ctrl+V or right-click Paste: replace local from clipboard. Ctrl+P: merge paste. Right-click: Clear.">
                <Grid>
                    <Image Source="avares://SLH/Assets/local-empty-duck.png"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="16"
                           Opacity="0.01"
                           IsVisible="{Binding ShowLocalEmptyPlaceholder}"/>
                    <ListBox x:Name="LocalPilotsList" ItemsSource="{Binding Pilots}" SelectedItem="{Binding SelectedPilot}"
                         Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                         DoubleTapped="OnLocalPilotsDoubleTapped"
                         ToolTip.Tip="Double-click: open zKill (when character ID is resolved). Ctrl+V: replace paste. Ctrl+P: merge paste. Right-click: menu.">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="1,0"/>
                            <Setter Property="MinHeight" Value="22"/>
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(odd) /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0a1016"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PilotRowViewModel">
                            <Grid ColumnDefinitions="2,*" Margin="0">
                            <Border Grid.Column="0" Width="2" VerticalAlignment="Stretch"
                                    Background="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}">
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                </ToolTip.Tip>
                            </Border>
                            <DockPanel Grid.Column="1" LastChildFill="True" Margin="1,0,0,0">
                                <!-- Dock Right: first = outermost right (threat), then cyno, friendly, unresolved -->
                                <Panel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <Border Padding="4,2" BorderThickness="1" Background="#2a1f32" BorderBrush="#7B1FA2"
                                            IsVisible="{Binding ShowThreatPendingPlaceholder}">
                                        <TextBlock Text="????" FontWeight="SemiBold" FontSize="8" Foreground="#CE93D8"
                                                   ToolTip.Tip="zKill threat not loaded yet"/>
                                    </Border>
                                    <Border Padding="3,1" BorderThickness="1"
                                            Background="{Binding ThreatBadgeBackground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            BorderBrush="{Binding ThreatBadgeBorderBrush, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            IsVisible="{Binding ShowThreatBadgeValues}">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="{Binding ThreatLabel}" FontWeight="SemiBold" FontSize="8"
                                                       Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            <TextBlock Text="{Binding ThreatScore}" FontWeight="SemiBold" FontSize="8" MinWidth="12"
                                                       Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                        </StackPanel>
                                    </Border>
                                </Panel>
                                <Border DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center" Margin="6,0,0,0"
                                        IsVisible="{Binding HasZkillCynoHint}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <TextBlock Text="cyno" FontSize="7" Foreground="#CE93D8" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock DockPanel.Dock="Right" Text="✓" Foreground="#388E3C" FontSize="8" VerticalAlignment="Center"
                                           Margin="6,0,0,0" IsVisible="{Binding IsFriendly}"/>
                                <TextBlock DockPanel.Dock="Right" Text="?" FontSize="9" Foreground="#9a8a70" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Margin="6,0,0,0" ToolTip.Tip="Resolving character…"
                                           IsVisible="{Binding IsCharacterUnresolved}"/>

                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Panel Width="16" Height="16" VerticalAlignment="Center">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <Border Width="16" Height="16" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True">
                                            <Image Width="16" Height="16" Source="{Binding PortraitBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}"/>
                                        </Border>
                                        <TextBlock Text="♦" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5a7090"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNull}}"/>
                                    </Panel>
                                    <Border Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontSize="11" LineHeight="13" TextTrimming="CharacterEllipsis"
                                                       Opacity="{Binding ListNameOpacity}"
                                                       Foreground="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            <TextBlock Text="{Binding CorpTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="9" Foreground="#8a9aaa" IsVisible="{Binding HasCorpTicker}"/>
                                            <TextBlock Text="{Binding AllianceTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="9" Foreground="#9aaa8a" IsVisible="{Binding HasAllianceTicker}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Classes="glass" Padding="6">
            <ScrollViewer>
                <StackPanel Spacing="4">
                    <TextBlock Text="Pilot" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8"/>

                    <StackPanel IsVisible="{Binding SelectedPilot, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="44" Height="44" CornerRadius="0" Background="#0a0e14" BorderBrush="#2A4B7C" BorderThickness="1" ClipToBounds="True"
                                    DataContext="{Binding SelectedPilot}">
                                <Panel>
                                    <Image Width="44" Height="44" Source="{Binding PortraitBitmap}" Stretch="UniformToFill"
                                           IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Text="♦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#5a7090"
                                               IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNull}}"/>
                                </Panel>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedPilot.Name}" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{Binding SelectedPilot.StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                <StackPanel Margin="0,3,0,0" Spacing="1" IsVisible="{Binding SelectedPilot.HasCorpDetail}">
                                    <TextBlock Text="Corporation" FontSize="9" Opacity="0.55"/>
                                    <TextBlock Text="{Binding SelectedPilot.CorpDetailLine}" FontSize="10" TextWrapping="Wrap" Foreground="#8a9aaa"/>
                                </StackPanel>
                                <StackPanel Margin="0,2,0,0" Spacing="1" IsVisible="{Binding SelectedPilot.HasAllianceDetail}">
                                    <TextBlock Text="Alliance" FontSize="9" Opacity="0.55"/>
                                    <TextBlock Text="{Binding SelectedPilot.AllianceDetailLine}" FontSize="10" TextWrapping="Wrap" Foreground="#8a9aaa"/>
                                </StackPanel>
                                <Panel Margin="0,3,0,0" HorizontalAlignment="Left">
                                    <Border Padding="6,3" BorderThickness="1" Background="#2a1f32" BorderBrush="#7B1FA2"
                                            IsVisible="{Binding SelectedPilot.ShowThreatPendingPlaceholder}">
                                        <TextBlock Text="????" FontWeight="SemiBold" FontSize="10" Foreground="#CE93D8"
                                                   ToolTip.Tip="zKill threat not loaded yet"/>
                                    </Border>
                                    <Border Padding="4,2" BorderThickness="1"
                                            Background="{Binding SelectedPilot.ThreatBadgeBackground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            BorderBrush="{Binding SelectedPilot.ThreatBadgeBorderBrush, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            IsVisible="{Binding SelectedPilot.ShowThreatBadgeValues}">
                                        <TextBlock FontWeight="SemiBold" FontSize="10"
                                                   Foreground="{Binding SelectedPilot.ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}">
                                            <Run Text="{Binding SelectedPilot.ThreatLabel}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding SelectedPilot.ThreatScore}"/>
                                        </TextBlock>
                                    </Border>
                                </Panel>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="10">
                            <Run Text="Kills " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsDestroyed}"/>
                            <Run Text="  Losses " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsLost}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedPilot.ShipsHint}" TextWrapping="Wrap" Opacity="0.8" FontSize="10"/>
                        <StackPanel Spacing="2" IsVisible="{Binding SelectedPilot.HasZkillDetail}">
                            <TextBlock Text="zKill (characterID stats)" FontWeight="SemiBold" FontSize="10" Foreground="#00a8b8"/>
                            <TextBlock Text="{Binding SelectedPilot.ZkillRatiosLine}" TextWrapping="Wrap" Opacity="0.9" FontSize="10"/>
                            <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.85">
                                <Run Text="Solo kills " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ZkillSoloKills}"/>
                                <Run Text="  Solo losses " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ZkillSoloLosses}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedPilot.ZkillPvpSummary}" TextWrapping="Wrap" FontSize="10" Opacity="0.9"/>
                            <TextBlock Text="{Binding SelectedPilot.ZkillCynoHint}" TextWrapping="Wrap" FontSize="10" Foreground="#CE93D8" Opacity="0.95"
                                       IsVisible="{Binding SelectedPilot.HasZkillCynoHint}"/>
                            <TextBlock Text="{x:Static services:ZkillIntelHeuristics.Disclaimer}" TextWrapping="Wrap" FontSize="9" Opacity="0.55" FontStyle="Italic"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedPilot.ActivityRegion}" FontWeight="SemiBold" FontSize="10" Foreground="#00a8b8"/>
                        <TextBlock Text="Activity heatmap (UTC, zKill activity)" Opacity="0.5" FontSize="9"/>
                        <TextBlock Text="{Binding ActivityHeatmapUtcLine}" TextWrapping="Wrap" FontSize="9" Opacity="0.85"/>
                        <ItemsControl ItemsSource="{Binding ActivityHeatmap}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ActivityHeatmapCellViewModel">
                                    <Border Width="6" MaxHeight="40" MinHeight="2" VerticalAlignment="Bottom"
                                            Height="{Binding BarHeight}" Background="#F57C00" CornerRadius="0"
                                            BorderThickness="1"
                                            BorderBrush="{Binding IsCurrentUtcHour, Converter={x:Static slh:BoolBrushConverter.HeatmapCurrentHourOutline}}"
                                            ToolTip.Tip="{Binding Tooltip}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="10" Foreground="#00b8c8"/>
                        <TextBlock Text="{Binding DetailNotes}" TextWrapping="Wrap" Opacity="0.9" FontSize="10"/>
                        <TextBlock Text="{Binding SelectedPilot.IntelTip}" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.75" FontSize="10"/>
                    </StackPanel>

                    <TextBlock Text="Select a pilot."
                               IsVisible="{Binding SelectedPilot, Converter={x:Static avalconv:ObjectConverters.IsNull}}"
                               Opacity="0.5" FontSize="10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
