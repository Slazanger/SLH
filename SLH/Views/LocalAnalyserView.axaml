<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalconv="using:Avalonia.Data.Converters"
             xmlns:slh="using:SLH.Converters"
             xmlns:vm="using:SLH.ViewModels"
             xmlns:services="using:SLH.Services"
             x:Class="SLH.Views.LocalAnalyserView"
             x:DataType="vm:LocalAnalyserViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <ContextMenu x:Key="LocalPilotsContextMenu">
            <MenuItem Header="Paste" Click="OnPasteLocalClick"/>
            <MenuItem Header="Clear" Click="OnClearLocalClick"/>
            <Separator/>
            <MenuItem Header="Custom tag">
                <MenuItem Header="FC" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="Cloaky Camper" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="JF Hunter" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
                <MenuItem Header="Ganker" ToggleType="CheckBox" Click="OnCustomTagMenuItemClick"/>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="0,2,0,0" MinHeight="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="300" MinWidth="280"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" RowDefinitions="*" Margin="0,0,6,0" MinHeight="0" VerticalAlignment="Stretch">
            <Border x:Name="LocalPilotsHost" Classes="glass" Padding="2" MinHeight="0" VerticalAlignment="Stretch"
                    ToolTip.Tip="Ctrl+V or right-click Paste: replace local from clipboard. Ctrl+P: merge paste. Right-click: Clear.">
                <Grid MinHeight="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Image Source="avares://SLH/Assets/local-empty-duck.png"
                           Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="16"
                           Opacity="0.01"
                           IsVisible="{Binding ShowLocalEmptyPlaceholder}"/>
                    <ListBox x:Name="LocalPilotsList" ItemsSource="{Binding Pilots}" SelectedItem="{Binding SelectedPilot}"
                         Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                         DoubleTapped="OnLocalPilotsDoubleTapped"
                         ToolTip.Tip="Double-click: open zKill (when character ID is resolved). Ctrl+V: replace paste. Ctrl+P: merge paste. Right-click: menu.">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="2,2"/>
                            <Setter Property="MinHeight" Value="28"/>
                        </Style>
                        <Style Selector="ListBoxItem:nth-child(odd) /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0a1016"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PilotRowViewModel">
                            <Grid ColumnDefinitions="3,*" Margin="0,0,15,0">
                            <Border Grid.Column="0" Width="3" VerticalAlignment="Stretch"
                                    Background="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}">
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                </ToolTip.Tip>
                            </Border>
                            <DockPanel Grid.Column="1" LastChildFill="True" Margin="2,0,0,0">
                                <!-- Dock Right: first = outermost right — tags + threat grouped on the right -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <Border Padding="4,1" CornerRadius="2" Background="#1a3a4a" BorderBrush="#2a5a6a"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding ShowFcBadge}">
                                        <TextBlock Text="FC" FontSize="8" FontWeight="SemiBold" Foreground="#7ec8e8" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#2a1f32" BorderBrush="#5a3a6a"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagCloakyCamper}">
                                        <TextBlock Text="Cloaky" FontSize="8" FontWeight="SemiBold" Foreground="#CE93D8" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#2a2618" BorderBrush="#8D6E63"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagJfHunter}">
                                        <TextBlock Text="JF" FontSize="8" FontWeight="SemiBold" Foreground="#FFCC80" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Padding="4,1" CornerRadius="2" Background="#3a1a1a" BorderBrush="#c62828"
                                            BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding TagGanker}">
                                        <TextBlock Text="Gank" FontSize="8" FontWeight="SemiBold" Foreground="#ef9a9a" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="2,0,4,0">
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap1, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip1}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap1}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap2, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip2}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap2}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Width="18" Height="18" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                IsVisible="{Binding TopShipBitmap3, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding TopShipTooltip3}" TextWrapping="Wrap" MaxWidth="240" FontSize="11"/>
                                            </ToolTip.Tip>
                                            <Image Width="18" Height="18" Source="{Binding TopShipBitmap3}" Stretch="UniformToFill"/>
                                        </Border>
                                    </StackPanel>
                                    <Panel VerticalAlignment="Center">
                                        <Border Padding="5,3" BorderThickness="1" Background="#2a1f32" BorderBrush="#7B1FA2"
                                                IsVisible="{Binding ShowThreatPendingPlaceholder}">
                                            <TextBlock Text="????" FontWeight="SemiBold" FontSize="9" Foreground="#CE93D8"
                                                       ToolTip.Tip="zKill threat not loaded yet"/>
                                        </Border>
                                        <Border Padding="4,2" BorderThickness="1"
                                                Background="{Binding ThreatBadgeBackground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                                BorderBrush="{Binding ThreatBadgeBorderBrush, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                                IsVisible="{Binding ShowThreatBadgeValues}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding ThreatLabel}" FontWeight="SemiBold" FontSize="9"
                                                           Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                                <TextBlock Text="{Binding ThreatScore}" FontWeight="SemiBold" FontSize="9" MinWidth="14"
                                                           Foreground="{Binding ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center" Margin="8,0,0,0"
                                        IsVisible="{Binding HasZkillCynoHint}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                    </ToolTip.Tip>
                                    <TextBlock Text="cyno" FontSize="8" Foreground="#CE93D8" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock DockPanel.Dock="Right" Text="?" FontSize="10" Foreground="#9a8a70" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Margin="8,0,0,0" ToolTip.Tip="Resolving character…"
                                           IsVisible="{Binding IsCharacterUnresolved}"/>

                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Panel Width="20" Height="20" VerticalAlignment="Center">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <Border Width="20" Height="20" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True">
                                            <Image Width="20" Height="20" Source="{Binding PortraitBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}"/>
                                        </Border>
                                        <TextBlock Text="♦" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5a7090"
                                                   IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNull}}"/>
                                    </Panel>
                                    <Border Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <ToolTip.Tip>
                                            <TextBlock Text="{Binding RowTooltip}" TextWrapping="Wrap" MaxWidth="280" FontSize="11"/>
                                        </ToolTip.Tip>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       FontSize="12" LineHeight="15" TextTrimming="CharacterEllipsis"
                                                       Opacity="{Binding ListNameOpacity}"
                                                       Foreground="{Binding StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                            <TextBlock Text="{Binding CorpTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="#8a9aaa" IsVisible="{Binding HasCorpTicker}"/>
                                            <TextBlock Text="{Binding AllianceTicker, StringFormat='[{0}]'}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="#9aaa8a" IsVisible="{Binding HasAllianceTicker}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DockPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" Background="#2d3d50" ResizeDirection="Columns"/>

        <Border Grid.Column="2" Classes="glass" Padding="8" VerticalAlignment="Stretch" MinHeight="0">
            <ScrollViewer Padding="0,0,0,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel Spacing="6">
                    <TextBlock Text="Pilot" FontWeight="SemiBold" FontSize="12" Foreground="#00b8c8"/>

                    <StackPanel IsVisible="{Binding SelectedPilot, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="44" Height="44" CornerRadius="0" Background="#0a0e14" BorderBrush="#2A4B7C" BorderThickness="1" ClipToBounds="True"
                                    DataContext="{Binding SelectedPilot}">
                                <Panel>
                                    <Image Width="44" Height="44" Source="{Binding PortraitBitmap}" Stretch="UniformToFill"
                                           IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}"/>
                                    <TextBlock Text="♦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#5a7090"
                                               IsVisible="{Binding PortraitBitmap, Converter={x:Static avalconv:ObjectConverters.IsNull}}"/>
                                </Panel>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedPilot.Name}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" LineHeight="16"
                                           Foreground="{Binding SelectedPilot.StandingForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,3,0,0" IsVisible="{Binding SelectedPilot.HasAnyCustomTag}">
                                    <TextBlock Text="Tags" FontSize="10" Foreground="#8490a0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedPilot.CustomTagsLine}" FontSize="10" Foreground="#9ec8d8" TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,4,0,0" Spacing="2" IsVisible="{Binding SelectedPilot.HasCorpDetail}">
                                    <TextBlock Text="Corporation" FontSize="10" Foreground="#8490a0"/>
                                    <TextBlock Text="{Binding SelectedPilot.CorpDetailLine}" FontSize="11" TextWrapping="Wrap" LineHeight="15" Foreground="#9aa8b6"/>
                                </StackPanel>
                                <StackPanel Margin="0,3,0,0" Spacing="2" IsVisible="{Binding SelectedPilot.HasAllianceDetail}">
                                    <TextBlock Text="Alliance" FontSize="10" Foreground="#8490a0"/>
                                    <TextBlock Text="{Binding SelectedPilot.AllianceDetailLine}" FontSize="11" TextWrapping="Wrap" LineHeight="15" Foreground="#9aa8b6"/>
                                </StackPanel>
                                <Panel Margin="0,4,0,0" HorizontalAlignment="Left">
                                    <Border Padding="6,3" BorderThickness="1" Background="#2a1f32" BorderBrush="#7B1FA2"
                                            IsVisible="{Binding SelectedPilot.ShowThreatPendingPlaceholder}">
                                        <TextBlock Text="????" FontWeight="SemiBold" FontSize="11" Foreground="#CE93D8"
                                                   ToolTip.Tip="zKill threat not loaded yet"/>
                                    </Border>
                                    <Border Padding="4,2" BorderThickness="1"
                                            Background="{Binding SelectedPilot.ThreatBadgeBackground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            BorderBrush="{Binding SelectedPilot.ThreatBadgeBorderBrush, Converter={x:Static slh:HexColorToBrushConverter.Instance}}"
                                            IsVisible="{Binding SelectedPilot.ShowThreatBadgeValues}">
                                        <TextBlock FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{Binding SelectedPilot.ThreatForeground, Converter={x:Static slh:HexColorToBrushConverter.Instance}}">
                                            <Run Text="{Binding SelectedPilot.ThreatLabel}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding SelectedPilot.ThreatScore}"/>
                                        </TextBlock>
                                    </Border>
                                </Panel>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="#2d3d50" Margin="0,2,0,0"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="15">
                            <Run Text="Kills " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsDestroyed}" Foreground="#c4ccd4"/>
                            <Run Text="  Losses " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ShipsLost}" Foreground="#c4ccd4"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedPilot.ShipsHint}" TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#aab4be"/>

                        <StackPanel Spacing="4" IsVisible="{Binding SelectedPilot.HasZkillDetail}">
                            <TextBlock Text="{Binding SelectedPilot.ZkillRatiosLine}" TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#b4bcc6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#c4ccd4">
                                <Run Text="Solo kills " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ZkillSoloKills}"/>
                                <Run Text="  Solo losses " Foreground="#8a9aaa"/><Run Text="{Binding SelectedPilot.ZkillSoloLosses}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedPilot.ZkillPvpSummary}" TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#b4bcc6"/>
                            <TextBlock Text="{Binding SelectedPilot.ZkillCynoHint}" TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#d4a5e8"
                                       IsVisible="{Binding SelectedPilot.HasZkillCynoHint}"/>
                        </StackPanel>

                        <Border Height="1" Background="#2d3d50" Margin="0,2,0,0"/>

                        <TextBlock Text="{Binding SelectedPilot.ActivityRegion}" FontWeight="SemiBold" FontSize="11" Foreground="#00a8b8" Margin="0,2,0,0"/>
                        <TextBlock Text="Activity heatmap (UTC, zKill activity)" FontSize="10" Foreground="#8490a0"/>
                        <TextBlock Text="{Binding ActivityHeatmapUtcLine}" TextWrapping="Wrap" FontSize="10" LineHeight="14" Foreground="#a8b2bc"/>
                        <ItemsControl ItemsSource="{Binding ActivityHeatmap}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ActivityHeatmapCellViewModel">
                                    <Border Width="8" MaxHeight="40" MinHeight="2" VerticalAlignment="Bottom"
                                            Height="{Binding BarHeight}" Background="#F57C00" CornerRadius="0"
                                            BorderThickness="1"
                                            BorderBrush="{Binding IsCurrentUtcHour, Converter={x:Static slh:BoolBrushConverter.HeatmapCurrentHourOutline}}"
                                            ToolTip.Tip="{Binding Tooltip}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Spacing="6" Margin="0,2,0,0" IsVisible="{Binding SelectedPilot.HasTopShipDetail}">
                            <TextBlock Text="Top hulls (zKill)" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8"/>
                            <StackPanel Spacing="8" DataContext="{Binding SelectedPilot}">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding TopShipBitmap1, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                    <Border Width="36" Height="36" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True"
                                            VerticalAlignment="Top">
                                        <Image Width="36" Height="36" Source="{Binding TopShipBitmap1}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding TopShipTooltip1}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11"
                                               LineHeight="15" Foreground="#b4bcc6"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding TopShipBitmap2, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                    <Border Width="36" Height="36" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True"
                                            VerticalAlignment="Top">
                                        <Image Width="36" Height="36" Source="{Binding TopShipBitmap2}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding TopShipTooltip2}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11"
                                               LineHeight="15" Foreground="#b4bcc6"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding TopShipBitmap3, Converter={x:Static avalconv:ObjectConverters.IsNotNull}}">
                                    <Border Width="36" Height="36" Background="#0a0e14" BorderBrush="#2d3d50" BorderThickness="1" ClipToBounds="True"
                                            VerticalAlignment="Top">
                                        <Image Width="36" Height="36" Source="{Binding TopShipBitmap3}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding TopShipTooltip3}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11"
                                               LineHeight="15" Foreground="#b4bcc6"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="#2d3d50" Margin="0,2,0,0"/>

                        <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding DetailNotes}" TextWrapping="Wrap" FontSize="11" LineHeight="15" Foreground="#b8c2cc"/>


                    </StackPanel>

                    <TextBlock Text="Select a pilot."
                               IsVisible="{Binding SelectedPilot, Converter={x:Static avalconv:ObjectConverters.IsNull}}"
                               FontSize="11" Foreground="#8a96a4"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
