<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:vm="using:SLH.ViewModels"
             x:Class="SLH.Views.CharacterLookupView"
             x:DataType="vm:CharacterLookupViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Watermark="Character name" Text="{Binding SearchName}" MinWidth="280"/>
                <Button Content="Look up" Command="{Binding LookupCommand}" Padding="16,8"/>
            </StackPanel>
            <TextBlock Text="{Binding Status}" Foreground="#f97316" TextWrapping="Wrap"
                       IsVisible="{Binding ShowStatus}"/>

            <Border Classes="glass" IsVisible="{Binding HasResult}">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="4">
                    <Border Grid.RowSpan="5" Width="120" Height="120" Margin="0,0,16,0" CornerRadius="8" ClipToBounds="True" Background="#111827">
                        <Image Source="{Binding PortraitBitmap}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding ResolvedName}" FontWeight="Bold" FontSize="18"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Margin="0,6,0,0">
                        <Run Text="Corporation: "/><Run Text="{Binding CorpName}"/> <Run Text="["/><Run Text="{Binding CorpTicker}"/><Run Text="]"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Grid.Row="2" Margin="0,8,0,0">
                        <Run Text="Threat: "/><Run Text="{Binding ThreatLabel}"/><Run Text=" ("/><Run Text="{Binding ThreatScore}"/><Run Text=")"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Grid.Row="3" Margin="0,8,0,0">
                        <Run Text="Ships destroyed / lost: "/><Run Text="{Binding ShipsDestroyed}"/><Run Text=" / "/><Run Text="{Binding ShipsLost}"/>
                    </TextBlock>

                    <ItemsControl Grid.Column="1" Grid.Row="4" Margin="0,12,0,0" ItemsSource="{Binding ActivityBuckets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sys:Int32">
                                <Border Width="10" MaxHeight="80" MinHeight="4" VerticalAlignment="Bottom"
                                        Height="{Binding}" Background="#38bdf8" CornerRadius="1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
