<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:vm="using:SLH.ViewModels"
             x:Class="SLH.Views.CharacterLookupView"
             x:DataType="vm:CharacterLookupViewModel">

    <ScrollViewer>
        <StackPanel Spacing="6" Margin="0,2,0,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Watermark="Character" Text="{Binding SearchName}" MinWidth="200"/>
                <Button Content="Look up" Command="{Binding LookupCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding Status}" Foreground="#F57C00" TextWrapping="Wrap" FontSize="10"
                       IsVisible="{Binding ShowStatus}"/>

            <Border Classes="glass" IsVisible="{Binding HasResult}" Padding="6">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0">
                    <Border Grid.RowSpan="5" Width="80" Height="80" Margin="0,0,8,0" CornerRadius="0" ClipToBounds="True" Background="#0a0e14" BorderBrush="#2A4B7C" BorderThickness="1">
                        <Image Source="{Binding PortraitBitmap}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding ResolvedName}" FontWeight="SemiBold" FontSize="12" Foreground="#e8eef4"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Margin="0,2,0,0" FontSize="10">
                        <Run Text="Corp " Foreground="#8a9aaa"/><Run Text="{Binding CorpName}"/> <Run Text="["/><Run Text="{Binding CorpTicker}"/><Run Text="]"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Grid.Row="2" Margin="0,4,0,0" FontSize="10">
                        <Run Text="Threat " Foreground="#8a9aaa"/><Run Text="{Binding ThreatLabel}"/><Run Text=" ("/><Run Text="{Binding ThreatScore}"/><Run Text=")"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Grid.Row="3" Margin="0,2,0,0" FontSize="10">
                        <Run Text="K/L " Foreground="#8a9aaa"/><Run Text="{Binding ShipsDestroyed}"/><Run Text="/"/><Run Text="{Binding ShipsLost}"/>
                    </TextBlock>

                    <ItemsControl Grid.Column="1" Grid.Row="4" Margin="0,6,0,0" ItemsSource="{Binding ActivityBuckets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sys:Int32">
                                <Border Width="7" MaxHeight="44" MinHeight="2" VerticalAlignment="Bottom"
                                        Height="{Binding}" Background="#00a0b0" CornerRadius="0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
