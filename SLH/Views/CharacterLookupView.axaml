<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SLH.ViewModels"
             xmlns:views="using:SLH.Views"
             x:Class="SLH.Views.CharacterLookupView"
             x:DataType="vm:CharacterLookupViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <ScrollViewer HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <StackPanel Spacing="6" Margin="0,2,0,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Watermark="Character" Text="{Binding SearchName}" MinWidth="200"/>
                <Button Content="Look up" Command="{Binding LookupCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding Status}" Foreground="#F57C00" TextWrapping="Wrap" FontSize="10"
                       IsVisible="{Binding ShowStatus}"/>

            <Border Classes="glass" IsVisible="{Binding HasResult}" Padding="8">
                <views:PilotDetailPanelView HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
