<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SLH.ViewModels"
             x:Class="SLH.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="8" Margin="0,2,0,0">
            <TextBlock Text="EVE application" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="10"
                       Text="developers.eveonline.com — callback must be http://127.0.0.1:&lt;port&gt;/callback/ (PKCE, no secret)."/>

            <StackPanel Spacing="2">
                <TextBlock Text="Client ID" FontSize="10" Opacity="0.8"/>
                <TextBox Text="{Binding EveClientId}" Watermark="Client ID"/>
            </StackPanel>

            <StackPanel Spacing="2">
                <TextBlock Text="Callback port" FontSize="10" Opacity="0.8"/>
                <NumericUpDown Value="{Binding CallbackPort}" Minimum="1024" Maximum="65535" Increment="1"/>
            </StackPanel>

            <StackPanel Spacing="2">
                <TextBlock Text="ChatLogs folder" FontSize="10" Opacity="0.8"/>
                <TextBox Text="{Binding ChatLogsFolder}" Watermark="...\EVE\logs\ChatLogs"/>
            </StackPanel>

            <CheckBox Content="zKill intel" IsChecked="{Binding EnableZkillIntel}"/>

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <Button Content="Log out" Command="{Binding LogoutCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
