<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SLH.ViewModels"
             x:Class="SLH.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="8" Margin="0,2,0,0">
            <TextBlock Text="EVE / ESI" FontWeight="SemiBold" FontSize="11" Foreground="#00b8c8"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="10"
                       Text="Client ID and callback port are compiled in (EsiBuildSettings.cs). Rebuild after changing them."/>

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Log in with EVE" Command="{Binding LoginCommand}" Padding="10,4"/>
                <Button Content="Log out" Command="{Binding LogoutCommand}" Padding="10,4"/>
            </StackPanel>

            <StackPanel Spacing="2">
                <TextBlock Text="ChatLogs folder" FontSize="10" Opacity="0.8"/>
                <TextBox Text="{Binding ChatLogsFolder}" Watermark="...\EVE\logs\ChatLogs"/>
            </StackPanel>

            <CheckBox Content="zKill intel" IsChecked="{Binding EnableZkillIntel}"/>

            <Button Content="Save" Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
